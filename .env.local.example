# Copy to .env.local and fill in once a Supabase project exists.
# The app runs on localhost; Supabase is the backend (cloud project, or local stack if Docker is installed).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# server-only (never expose to the browser) — used for admin scripts / bulk deal import
SUPABASE_SERVICE_ROLE_KEY=
