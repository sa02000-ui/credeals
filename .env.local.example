# Copy to .env.local and fill in once a Supabase project exists.
# NOTE: credeals uses NEXT_PUBLIC_SB_* (NOT the standard NEXT_PUBLIC_SUPABASE_*) on purpose —
# this machine has global NEXT_PUBLIC_SUPABASE_* vars for the separate am-portal project, and
# distinct names guarantee credeals never connects to the wrong database.
NEXT_PUBLIC_SB_URL=
NEXT_PUBLIC_SB_ANON_KEY=
# server-only (never exposed to the browser) — used for admin scripts / bulk deal import
SB_SERVICE_ROLE_KEY=
